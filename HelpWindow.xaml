<Window x:Class="BluetoothAudioReceiver.HelpWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Help"
        Height="550" Width="500"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="NoResize"
        Background="Transparent">
    
    <Border Background="{StaticResource BackgroundBrush}" 
            BorderBrush="{StaticResource BorderBrush}" 
            BorderThickness="1" 
            CornerRadius="12">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            
            <!-- Custom Title Bar -->
            <Border Background="{StaticResource SurfaceBrush}" 
                    CornerRadius="12,12,0,0"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid>
                    <StackPanel Orientation="Horizontal" Margin="16,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="❓" FontSize="14" Margin="0,0,8,0"/>
                        <TextBlock x:Name="TitleBarText" Text="Help" 
                                   FontSize="13" 
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                    </StackPanel>
                    
                    <Button x:Name="CloseButton" Content="✕" 
                            Click="CloseButton_Click"
                            Style="{StaticResource CloseButtonStyle}"
                            HorizontalAlignment="Right"
                            FontSize="12"
                            Foreground="{StaticResource TextSecondaryBrush}"
                            ToolTip="Close"
                            AutomationProperties.Name="Close"/>
                </Grid>
            </Border>
            
            <!-- Content -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="20">
                <StackPanel>
                    
                    <!-- Quick Start -->
                    <TextBlock x:Name="QuickStartHeader" Text="Quick Start" Style="{StaticResource SectionHeaderStyle}"/>
                    <Border Style="{StaticResource CardStyle}" Margin="0,0,0,20">
                        <StackPanel>
                            <TextBlock x:Name="QuickStartText" TextWrapping="Wrap" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,12">
                                <Run FontWeight="SemiBold">1.</Run> Pair phone in Windows Bluetooth settings<LineBreak/>
                                <Run FontWeight="SemiBold">2.</Run> Start app and select device from list<LineBreak/>
                                <Run FontWeight="SemiBold">3.</Run> Click "Connect"<LineBreak/>
                                <Run FontWeight="SemiBold">4.</Run> Play audio on phone
                            </TextBlock>
                        </StackPanel>
                    </Border>
                    
                    <!-- Known Issues -->
                    <TextBlock x:Name="KnownIssuesHeader" Text="⚠️ Known Issues" Style="{StaticResource SectionHeaderStyle}"/>
                    <Border Style="{StaticResource CardStyle}" Margin="0,0,0,20">
                        <StackPanel>
                            
                            <!-- Issue 1 -->
                            <StackPanel Margin="0,0,0,16">
                                <TextBlock x:Name="NetworkSlowdownTitle" Text="Network/Download speed drops" 
                                           FontWeight="SemiBold" 
                                           Foreground="{StaticResource WarningBrush}"
                                           Margin="0,0,0,6"/>
                                <TextBlock x:Name="NetworkSlowdownDescText" TextWrapping="Wrap" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12">
                                    Bluetooth and WiFi often share the same 2.4 GHz frequency band, causing interference.
                                </TextBlock>
                                <Border Background="{StaticResource SurfaceVariantBrush}" 
                                        CornerRadius="6" 
                                        Padding="12" 
                                        Margin="0,8,0,0">
                                    <TextBlock x:Name="NetworkSolutionText" TextWrapping="Wrap" Foreground="{StaticResource TextPrimaryBrush}" FontSize="12">
                                        <Run FontWeight="SemiBold">Solution:</Run><LineBreak/>
                                        • Use 5 GHz WiFi (best option!)<LineBreak/>
                                        • Device Manager → WiFi adapter → Properties<LineBreak/>
                                        • Disable "Bluetooth Collaboration"<LineBreak/>
                                        • Use separate USB Bluetooth dongle
                                    </TextBlock>
                                </Border>
                            </StackPanel>
                            
                            <!-- Issue 2 -->
                            <StackPanel Margin="0,0,0,16">
                                <TextBlock x:Name="NoDevicesIssueTitle" Text="No devices in list" 
                                           FontWeight="SemiBold" 
                                           Foreground="{StaticResource WarningBrush}"
                                           Margin="0,0,0,6"/>
                                <Border Background="{StaticResource SurfaceVariantBrush}" 
                                        CornerRadius="6" 
                                        Padding="12">
                                    <TextBlock x:Name="NoDevicesSolutionText" TextWrapping="Wrap" Foreground="{StaticResource TextPrimaryBrush}" FontSize="12">
                                        <Run FontWeight="SemiBold">Solution:</Run><LineBreak/>
                                        • Pair phone with PC in Windows settings<LineBreak/>
                                        • Is Bluetooth enabled on phone and PC?<LineBreak/>
                                        • Windows 10 Version 2004+ or Windows 11 required
                                    </TextBlock>
                                </Border>
                            </StackPanel>
                            
                            <!-- Issue 3 -->
                            <StackPanel>
                                <TextBlock x:Name="ConnectionDropsTitle" Text="Connection drops" 
                                           FontWeight="SemiBold" 
                                           Foreground="{StaticResource WarningBrush}"
                                           Margin="0,0,0,6"/>
                                <Border Background="{StaticResource SurfaceVariantBrush}" 
                                        CornerRadius="6" 
                                        Padding="12">
                                    <TextBlock x:Name="ConnectionDropsSolutionText" TextWrapping="Wrap" Foreground="{StaticResource TextPrimaryBrush}" FontSize="12">
                                        <Run FontWeight="SemiBold">Solution:</Run><LineBreak/>
                                        • Update Bluetooth drivers<LineBreak/>
                                        • Device Manager → Bluetooth adapter → Disable power saving<LineBreak/>
                                        • Keep phone in range (&lt;10m)
                                    </TextBlock>
                                </Border>
                            </StackPanel>
                            
                        </StackPanel>
                    </Border>
                    
                    <!-- System Requirements -->
                    <TextBlock x:Name="SystemRequirementsHeader" Text="System Requirements" Style="{StaticResource SectionHeaderStyle}"/>
                    <Border Style="{StaticResource CardStyle}" Margin="0,0,0,20">
                        <TextBlock x:Name="RequirementsText" TextWrapping="Wrap" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12">
                            • Windows 10 Version 2004 (May 2020 Update) or newer<LineBreak/>
                            • Windows 11 (all versions)<LineBreak/>
                            • Bluetooth adapter with A2DP support<LineBreak/>
                            • Paired Bluetooth device (phone, tablet, etc.)
                        </TextBlock>
                    </Border>
                    
                    <!-- Version Info -->
                    <TextBlock x:Name="InfoHeader" Text="Info" Style="{StaticResource SectionHeaderStyle}"/>
                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Foreground="{StaticResource TextSecondaryBrush}" FontSize="12">
                                <Run x:Name="VersionLabelRun" Text="Version: "/><Run Text="2.0.0" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}"/><LineBreak/>
                                <Run x:Name="DevelopedWithRun" Text="Developed with .NET 8 and WPF"/>
                            </TextBlock>
                        </StackPanel>
                    </Border>
                    
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Border>
</Window>
